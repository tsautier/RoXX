# Manifest file for package data
include README.md
include LICENSE
include CHANGELOG.md
include QUICKSTART.md
include BUILD.md
include roxx_logo.png
include requirements.txt
include pyproject.toml

# Include all Python files
recursive-include roxx *.py

# Include config files
recursive-include roxx/config *.json
recursive-include roxx/web/templates *
recursive-include roxx/web/static *
recursive-include docs *.md
recursive-include packaging *
recursive-include deploy *
recursive-include scripts *.py *.ps1 *.sh
include ROADMAP.md


# Exclude tests and cache
recursive-exclude tests *
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude * .DS_Store
